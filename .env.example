# Subly 配置示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 基础认证 ----------
# 登录令牌密钥，生产环境必须改成随机强密钥：openssl rand -hex 32
JWT_SECRET=please-change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
# Refresh Token 使用 HttpOnly Cookie；HTTPS 部署请设 true，纯 HTTP 局域网保持 false
AUTH_COOKIE_NAME=subly_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# 仅本地演示可设 true 跳过危险默认值保护；公网部署禁止开启
ALLOW_INSECURE_DEFAULTS=false

# ---------- 管理员账号 ----------
# 启动时若该用户名不存在则创建；密码至少 12 位，示例占位值必须修改，否则首次启动会拒绝创建
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-this-admin-password
ADMIN_EMAIL=admin@example.com

# ---------- 时区、日志与调度 ----------
TZ=Asia/Shanghai
REMINDER_SCAN_TIME=09:00
# 对外可访问地址（如 https://subly.example.com）；仅影响 Bark 测试推送的点击跳转，真实续费提醒点击地址取订阅 url，留空不跳转
APP_PUBLIC_URL=
LOG_LEVEL=INFO
SLOW_REQUEST_MS=1000

# ---------- SQLite 数据库 ----------
# 一般无需修改；容器内建议保留在 /app/data 对应的数据卷下
DB_PATH=data/subly.db

# ---------- 注册审核 / 邮件验证 ----------
# 默认新注册用户需要管理员审核；如配置 SMTP，注册流程会发送邮箱验证码
REQUIRE_ADMIN_APPROVAL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# ---------- Telegram ----------
# 仅声明保留，当前不参与发送；Bot Token、Chat ID、API 反代、代理均为用户级网页设置
TELEGRAM_BOT_TOKEN=

# ---------- 汇率数据源 ----------
EXCHANGE_API_BASE=USD
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/
EXCHANGE_API_KEY=

# ---------- 内置图标库 favicon 下载 ----------
ICON_FETCH_ENABLED=true
ICON_FETCH_GOOGLE_ENABLED=true
ICON_FETCH_TIMEOUT_S=2.0
ICON_FETCH_MAX_BYTES=262144
ICON_FETCH_CONCURRENCY=6
ICON_FETCH_SVG_ENABLED=true

# Bark 的 Device Key、服务器、提示音、分组与 TTL 均在网页「设置」里按用户配置，无对应环境变量；APP_PUBLIC_URL 仅影响 Bark 测试推送的点击跳转。
