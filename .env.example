# Subly 配置示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 基础认证 ----------
# 登录令牌密钥，生产环境必须改成随机强密钥：openssl rand -hex 32
JWT_SECRET=please-change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---------- 首次初始化管理员 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# ---------- 时区、日志与调度 ----------
TZ=Asia/Shanghai
REMINDER_SCAN_TIME=09:00
# Subly 对外可访问地址（如 https://subly.example.com）；配置后 Bark 推送点击可跳转回应用，留空不跳转
APP_PUBLIC_URL=
LOG_LEVEL=INFO
SLOW_REQUEST_MS=1000

# ---------- SQLite 数据库 ----------
# 一般无需修改；容器内建议保留在 /app/data 对应的数据卷下
DB_PATH=data/subly.db

# ---------- 注册审核 / 邮件验证 ----------
# 默认新注册用户需要管理员审核；如配置 SMTP，注册流程会发送邮箱验证码
REQUIRE_ADMIN_APPROVAL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# ---------- Telegram ----------
# 可留空，后续在网页「设置」里配置；Chat ID、API 反代、代理等为用户级网页设置
TELEGRAM_BOT_TOKEN=

# ---------- 汇率数据源 ----------
EXCHANGE_API_BASE=USD
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/
EXCHANGE_API_KEY=

# ---------- 内置图标库 favicon 下载 ----------
ICON_FETCH_ENABLED=true
ICON_FETCH_GOOGLE_ENABLED=true
ICON_FETCH_TIMEOUT_S=2.0
ICON_FETCH_MAX_BYTES=262144
ICON_FETCH_CONCURRENCY=6
ICON_FETCH_SVG_ENABLED=true

# Bark 无需环境变量，登录后在网页「设置」里配置 Device Key、服务器、提示音、分组与 TTL。
